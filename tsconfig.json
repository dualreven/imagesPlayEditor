{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@modules": ["src/modules/index.ts"]
    },
    "types": ["vite/client", "node"]
  },
  "include": ["src", "vite.config.ts", "scripts/check-lines.mjs"]
}
