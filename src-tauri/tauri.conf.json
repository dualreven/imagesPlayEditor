{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "imagesPlayEditor",
  "version": "0.1.0",
  "identifier": "com.imagesplay.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:17641",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "imagesPlayEditor",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
